{
  "name": "claude-code-crawler",
  "version": "0.1.0",
  "description": "A roguelike deckbuilder that lives alongside Claude Code — crawl the dungeon while Claude works, return to the surface when it needs you.",
  "type": "module",
  "license": "MIT",
  "author": "Mitch",
  "keywords": [
    "claude-code",
    "claude",
    "roguelike",
    "deckbuilder",
    "tui",
    "hooks",
    "game"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitchjablonski/claude-code-crawler.git"
  },
  "homepage": "https://github.com/mitchjablonski/claude-code-crawler#readme",
  "bugs": {
    "url": "https://github.com/mitchjablonski/claude-code-crawler/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ccc": "./dist/cli.js",
    "crawler": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "ink": "^5.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.27.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0",
    "vitest": "^2.1.0"
  }
}
